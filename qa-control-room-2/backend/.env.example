# Comma-separated list of extra frontend origins allowed to call this API.
# http://localhost:5173 and http://127.0.0.1:5173 (Vite's defaults) are
# already allowed in app/main.py, so you usually don't need to set this
# for local development.
ALLOWED_ORIGINS=

# Only used once app/bedrock.py is wired up to a real Bedrock call.
BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
